{
  "slug": "maven-java",
  "description": "Maven build for Java projects",
  "definitions": [
    {
      "key": "packageName",
      "type": "STRING",
      "mandatory": true,
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)*$"
    },
    {
      "key": "buildTool",
      "type": "ENUM",
      "mandatory": true,
      "enumValues": ["MAVEN", "GRADLE"],
      "defaultValue": "MAVEN"
    },
    {
      "key": "verbose",
      "type": "BOOLEAN",
      "mandatory": false
    }
  ]
}
