{
  "name": "seed4j-mcp",
  "version": "1.1.2",
  "description": "MCP server exposing seed4j to AI agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avdev4j/seed4j-mcp.git"
  },
  "homepage": "https://github.com/avdev4j/seed4j-mcp#readme",
  "bugs": {
    "url": "https://github.com/avdev4j/seed4j-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "seed4j-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run format:check && npm run typecheck && npm run test && npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "verify:api": "tsx scripts/verify-seed4j-api.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
